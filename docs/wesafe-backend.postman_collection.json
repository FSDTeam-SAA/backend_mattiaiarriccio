    {
      "name": "User App",
      "auth": {
        "type": "bearer",
        "bearer": [
          { "key": "token", "value": "{{userAccessToken}}", "type": "string" }
        ]
      },
      "item": [
        {
          "name": "Get Home Payload",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/home",
            "description": "Returns the mobile home payload with greeting, quick actions, featured guides, checklist summary, and recent chat preview."
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/me",
            "description": "Returns the authenticated user profile."
          }
        },
        {
          "name": "Update Current User",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "username", "value": "Madiha", "type": "text" },
                { "key": "lastName", "value": "Aroa", "type": "text" },
                { "key": "phoneNumber", "value": "+8801700000000", "type": "text" },
                { "key": "avatar", "type": "file", "src": [] }
              ]
            },
            "url": "{{baseUrl}}/api/v1/users/me",
            "description": "Updates editable user profile fields. Accepts a single username or userName field. Upload avatar with multipart/form-data using the avatar file field."
          }
        },
        {
          "name": "Get User Preferences",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/me/preferences",
            "description": "Returns preferredLanguage, notificationsEnabled, onboardingCompleted, and supportedLanguages."
          }
        },
        {
          "name": "Update User Preferences",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"preferredLanguage\": \"bn\",\n  \"notificationsEnabled\": true,\n  \"onboardingCompleted\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/v1/users/me/preferences",
            "description": "Updates language, notifications, and onboarding flags."
          }
        },
        {
          "name": "Change User Password",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
