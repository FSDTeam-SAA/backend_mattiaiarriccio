            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"{{userPassword}}\",\n  \"newPassword\": \"{{newUserPassword}}\",\n  \"confirmNewPassword\": \"{{newUserPassword}}\"\n}",
