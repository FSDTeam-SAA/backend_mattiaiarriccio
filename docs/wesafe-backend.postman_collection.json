  "item": [
    {
      "name": "System & Docs",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/",
            "description": "Checks whether the Express backend is running and returns health plus docs links."
          }
        },
        {
          "name": "HTML Docs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/docs",
            "description": "Returns the built-in HTML docs page served by the backend."
          }
        },
        {
          "name": "JSON API Catalog",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/docs/json",
            "description": "Returns the backend API catalog in JSON format."
          }
        }
      ]
    },
    {
      "name": "Auth - User",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = null;",
                  "try { json = pm.response.json(); } catch (error) {}",
                  "if (json?.data?.accessToken) pm.collectionVariables.set('userAccessToken', json.data.accessToken);",
                  "if (json?.data?.user?.id) pm.collectionVariables.set('userId', json.data.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "username", "value": "{{newUserFirstName}}", "type": "text" },
                { "key": "lastName", "value": "{{newUserLastName}}", "type": "text" },
                { "key": "phoneNumber", "value": "{{newUserPhoneNumber}}", "type": "text" },
                { "key": "preferredLanguage", "value": "en", "type": "text" },
                { "key": "email", "value": "{{newUserEmail}}", "type": "text" },
                { "key": "password", "value": "{{newUserPassword}}", "type": "text" },
                { "key": "confirmPassword", "value": "{{newUserPassword}}", "type": "text" },
                { "key": "avatar", "type": "file", "src": [] }
              ]
            },
            "url": "{{baseUrl}}/api/v1/auth/register",
            "description": "Creates a mobile user account and returns an access token. Accepts a single username or userName field. Upload avatar with multipart/form-data using the avatar file field."
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = null;",
                  "try { json = pm.response.json(); } catch (error) {}",
                  "if (json?.data?.accessToken) pm.collectionVariables.set('userAccessToken', json.data.accessToken);",
                  "if (json?.data?.user?.id) pm.collectionVariables.set('userId', json.data.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/v1/auth/login",
            "description": "User email/password login. Saves userAccessToken and userId."
          }
        },
        {
          "name": "Social Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = null;",
                  "try { json = pm.response.json(); } catch (error) {}",
                  "if (json?.data?.accessToken) pm.collectionVariables.set('userAccessToken', json.data.accessToken);",
                  "if (json?.data?.user?.id) pm.collectionVariables.set('userId', json.data.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "provider", "value": "google", "type": "text" },
                { "key": "email", "value": "{{socialEmail}}", "type": "text" },
                { "key": "fullName", "value": "{{socialFullName}}", "type": "text" },
                { "key": "avatar", "type": "file", "src": [] }
              ]
            },
            "url": "{{baseUrl}}/api/v1/auth/social-login",
            "description": "Creates or refreshes a local user after social sign-in and returns a local session token. Upload avatar with multipart/form-data using the avatar file field."
          }
        },
        {
          "name": "Request User Password Reset OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = null;",
                  "try { json = pm.response.json(); } catch (error) {}",
                  "if (json?.data?.debugOtp) pm.collectionVariables.set('userResetOtp', json.data.debugOtp);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/v1/auth/password-reset/request",
            "description": "Starts the user password reset flow. Outside production the response includes debugOtp."
          }
        },
        {
          "name": "Verify User Password Reset OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = null;",
                  "try { json = pm.response.json(); } catch (error) {}",
                  "if (json?.data?.resetToken) pm.collectionVariables.set('userResetToken', json.data.resetToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"otpCode\": \"{{userResetOtp}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/v1/auth/password-reset/verify",
            "description": "Verifies the user OTP and saves userResetToken."
          }
        },
        {
          "name": "Reset User Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"resetToken\": \"{{userResetToken}}\",\n  \"password\": \"{{newUserPassword}}\",\n  \"confirmPassword\": \"{{newUserPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/v1/auth/password-reset/reset",
            "description": "Completes the user password reset flow."
          }
        },
        {
          "name": "Logout User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{userAccessToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/logout",
            "description": "Invalidates the current user session token."
          }
        }
      ]
    },
