          }
        }
      ]
    },
    {
      "name": "Checklists",
      "auth": {
        "type": "bearer",
        "bearer": [
          { "key": "token", "value": "{{userAccessToken}}", "type": "string" }
        ]
      },
      "item": [
        {
          "name": "List Checklists",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/checklists?search=earthquake&category=Earthquake",
            "description": "Lists published template checklists plus the current user's custom checklists."
          }
        },
        {
          "name": "Create Custom Checklist",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = null;",
                  "try { json = pm.response.json(); } catch (error) {}",
                  "if (json?.data?.id) pm.collectionVariables.set('customChecklistId', json.data.id);",
                  "if (json?.data?.items?.[0]?.id) pm.collectionVariables.set('customChecklistItemId', json.data.items[0].id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Apartment fire drill", "type": "text" },
                { "key": "category", "value": "Fire Safety", "type": "text" },
                { "key": "description", "value": "Track evacuation and extinguisher readiness at home.", "type": "text" },
                { "key": "items", "value": "[\"Test hallway smoke alarm\",\"Review escape route with family\"]", "type": "text" },
                { "key": "icon", "type": "file", "src": [] },
                { "key": "coverImage", "type": "file", "src": [] }
              ]
            },
            "url": "{{baseUrl}}/api/v1/checklists",
            "description": "Creates a user-owned custom checklist and saves customChecklistId. Upload images with multipart/form-data using icon and coverImage file fields. Send items as a JSON string."
          }
        },
        {
          "name": "Get Checklist By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/checklists/{{customChecklistId}}",
            "description": "Fetches a checklist with completion state. You can replace customChecklistId with templateChecklistId if needed."
          }
        },
        {
          "name": "Update Custom Checklist",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
