    { "key": "templateChecklistItemId", "value": "eq_item_1", "type": "string" },
    { "key": "notificationId", "value": "", "type": "string" },
    { "key": "userAccessToken", "value": "", "type": "string" },
    { "key": "adminAccessToken", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "adminId", "value": "", "type": "string" },
    { "key": "userResetOtp", "value": "", "type": "string" },
    { "key": "userResetToken", "value": "", "type": "string" },
    { "key": "adminResetOtp", "value": "", "type": "string" },
    { "key": "adminResetToken", "value": "", "type": "string" },
    { "key": "customChecklistId", "value": "", "type": "string" },
