    {
      "name": "Safety Tips",
      "auth": {
        "type": "bearer",
        "bearer": [
          { "key": "token", "value": "{{userAccessToken}}", "type": "string" }
        ]
      },
      "item": [
        {
          "name": "List Safety Tips",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/safety-tips?page=1&limit=10&search=fire&category=Fire%20Safety&featured=false",
            "description": "Lists published safety guides. Supports page, limit, search, category, and featured query parameters."
          }
        },
        {
          "name": "Get Safety Tip By ID Or Slug",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/safety-tips/{{publicTipIdOrSlug}}",
