PORT=5001
NODE_ENV=development
MONGODB_URI=mongodb+srv://fahim:fahim0037@mattiaiarriccio.tnumtnt.mongodb.net
SESSION_TTL_HOURS=168
RESET_OTP_TTL_MINUTES=10
AI_BACKEND_BASE_URL=https://mattiaiaricco-ai-chatbot.onrender.com
AI_TIMEOUT_MS=30000
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ALLOWED_CLIENT_IDS=
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM=

# --- In-app purchases: Google Play (subscriptions verification + RTDN webhook) ---
# JSON string of a Google service-account key with androidpublisher access
GOOGLE_PLAY_SA_JSON=
GOOGLE_PLAY_PACKAGE_NAME=

# --- In-app purchases: Apple App Store (App Store Server API + Notifications V2) ---
# PEM contents of the App Store Connect .p8 in-app-purchase key (\n escapes are normalized)
APPLE_IAP_KEY=
APPLE_IAP_KEY_ID=
APPLE_IAP_ISSUER_ID=
APPLE_BUNDLE_ID=
# 'production' (default) or 'sandbox'
APPLE_IAP_ENV=production

# --- Push notifications (FCM) for the reminder engine ---
# Full Firebase service-account JSON as a single string (preferred). If absent, push is a logged no-op.
FCM_SERVICE_ACCOUNT_JSON=
# Optional legacy FCM server key fallback (detection only)
FCM_SERVER_KEY=
